{
  "actorSpecification": 1,
  "name": "google-maps-scraper",
  "title": "Google Maps Scraper",
  "description": "Scrape places from Google Maps by search terms and location. Get name, address, phone, rating, reviews, website and more.",
  "version": "1.0",
  "buildTag": "latest",
  "environmentVariables": {},
  "dockerfile": "./Dockerfile",
  "readme": "./README.md",
  "input": "./input_schema.json",
  "storages": {
    "dataset": {
      "actorSpecification": 1,
      "title": "Scraped Places",
      "views": {
        "overview": {
          "title": "Overview",
          "transformation": {
            "fields": [
              "name",
              "category",
              "email",
              "maps_url",
              "phone",
              "place_id",
              "price",
              "rating",
              "review_count",
              "website",
              "address"
            ]
          },
          "display": {
            "component": "table",
            "properties": {
              "name":         { "label": "Name",         "format": "text"   },
              "category":     { "label": "Category",     "format": "text"   },
              "email":        { "label": "Email",        "format": "text"   },
              "maps_url":     { "label": "Maps URL",     "format": "link"   },
              "phone":        { "label": "Phone",        "format": "text"   },
              "place_id":     { "label": "Place ID",     "format": "text"   },
              "price":        { "label": "Price",        "format": "number" },
              "rating":       { "label": "Rating",       "format": "number" },
              "review_count": { "label": "Review Count", "format": "number" },
              "website":      { "label": "Website",      "format": "link"   },
              "address":      { "label": "Address",      "format": "text"   }
            }
          }
        }
      }
    }
  }
}
