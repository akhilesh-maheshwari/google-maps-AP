{
  "title": "Google Maps Scraper Input",
  "type": "object",
  "schemaVersion": 1,
  "properties": {
    "fileName": {
      "title": "File Name",
      "type": "string",
      "description": "Name for the output file",
      "editor": "textfield",
      "default": "output"
    },
    "searchTerms": {
      "title": "Search term(s)",
      "type": "array",
      "description": "List of search terms",
      "editor": "stringList",
      "prefill": ["hospitals"]
    },
    "location": {
      "title": "Location",
      "type": "string",
      "description": "Use only one location per run",
      "editor": "textfield",
      "prefill": "New York, USA"
    },
    "maxPlaces": {
      "title": "Number of places to extract (per search term)",
      "type": "integer",
      "description": "Maximum number of places to scrape for each search term",
      "editor": "number",
      "prefill": 150
    }
  },
  "required": ["searchTerms", "location"]
}
